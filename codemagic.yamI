workflows:
  android-release:
    name: Android APK Build
    environment:
      flutter: stable
    scripts:
      - name: Install dependencies
        working_directory: .
        script: flutter pub get
      - name: Build APK
        working_directory: .
        script: flutter build apk --release
    artifacts:
      - build/app/outputs/flutter-apk/app-release.apk
